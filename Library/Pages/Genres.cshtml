@page
@model MyApp.Namespace.GenresModel
@{
    ViewData["Title"] = "Lookup By Genre";
}
<h1>@ViewData["Title"]</h1>
<!-- Form for selecting a genre from the dropdown list -->
<form method="post">
    <div class="form-group">
        <label for="Genre">Select Genre:</label>
        <select class="form-control" id="Genre" name="Genre">
            <!-- Loop through the GenreList to populate the dropdown options -->
            @foreach (var genre in Model.GenreList)
            {
                <option value="@genre.Text" selected="@(Model.Genre == genre.Text ? "selected" : null)">@genre.Text</option>
            }
        </select>
    </div>
    <!-- Submit button to trigger the search for books based on the selected genre -->
    <button type="submit" class="btn btn-primary">Search</button>
</form>
<!-- If BookList is not null and contains books, display them in a table -->
@if (Model.BookList != null && Model.BookList.Count > 0)
{
    <h2 class="mt-4">Books by @Model.Genre</h2>
    <table class="table table-striped table-bordered mt-2">
        <thead>
            <tr>
                <th>Title</th>
                <th>ISBN</th>
                <th>Genre</th>
                <th>Author</th>
                <th>Publication Year</th>
                <th>Publisher</th>
            </tr>
        </thead>
        <tbody>
            <!-- Loop through the BookList to display each book's details in a table row -->
            @foreach (var book in Model.BookList)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.ISBN</td>
                    <td>@book.Genre</td>
                    <td>@book.Author_First_Name @book.Author_Last_Name</td>
                    <td>@book.Publication</td>
                    <td>@book.Publisher</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (Model.BookList != null)
{
    <div class="alert alert-warning mt-4">No books were found for the selected genre.</div>
}